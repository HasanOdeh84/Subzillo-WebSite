# ── SMTP (email notifications to info@subzillo.com) ────────────
# For Google Workspace / Gmail, generate an App Password:
# myaccount.google.com → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@subzillo.com
SMTP_PASS=your-app-password-here

# ── Admin token (for CSV export at /api/waitlist/export) ───────
# Generate a strong random string — keep it secret
ADMIN_TOKEN=change-me-to-something-secret

# ── Local dev only ──────────────────────────────────────────────
# Not needed when deployed to Cloud Run (auto-detected from service account).
# Required locally after: gcloud auth application-default login
PORT=3001
